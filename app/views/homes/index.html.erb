<h1>Homes#index</h1>
<p>Find me in app/views/homes/index.html.erb</p>

<h1> VRCお気に入りワールド管理ツール </h1>

<p> 追加予定 </p>
<section>
    <h2>VRCAPIで検索</h2>
    <%= form_with url: search_worlds_path, method: :get, local: true do |form| %>
        <%= form.label :worldname, "ワールド名を入力してください" %>
        <%= form.text_field :worldname, placaholder: "例: skipfloor" %>
        <%= form.submit "検索" %>
    <% end %>
</section>

<section>
    <h2>最近確認したワールド</h2>
    <p>routes GET /recent recent#index になる</p>
</section>

<section>
    <h2>タグで保存ワールドを検索</h2>
    <%= form_with url: tags_path, method: :get, local: true do |form| %>
        <%= form.label :tagname, "ワールド名を入力してください" %>
        <%= form.text_field :tagname, placaholder: "例: skipfloor" %>
        <%= form.submit "検索" %>
    <% end %>
</section>

<section>
    <h2>保存ワールドの全表示</h2>
    <%= link_to "全件表示", worlds_path %>
</section>